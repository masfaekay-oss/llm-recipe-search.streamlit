# Stages base, build, run, export are required by CI-CD-Pipeline/core/build-artifact-multistage.
# Each FROM must be a real registry image (not only a stage alias). Use docker.io/library/... so
# Jenkins getImageNamesFromDockerfile + pullAll parse images correctly.
ARG BUILD_TYPE
ARG GIT_BRANCH
ARG DRY_RUN
ARG DEBUG_LOGGING

FROM docker.io/library/python:3.8-slim AS base

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

FROM docker.io/library/python:3.8-slim AS build

WORKDIR /semantic_search_streamlit

COPY --from=base /etc/debian_version /tmp/base-debian_version

COPY requirements.txt /semantic_search_streamlit/requirements.txt

ENV PIP_DISABLE_PIP_VERSION_CHECK=1

RUN pip install --no-cache-dir -r requirements.txt

COPY . /semantic_search_streamlit

RUN python -c "import streamlit, elasticsearch, openai, requests, dotenv"

FROM docker.io/library/python:3.8-slim AS run

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

COPY --from=build /usr/local/lib/python3.8/site-packages /usr/local/lib/python3.8/site-packages

COPY --from=build /usr/local/bin /usr/local/bin

COPY --from=build /semantic_search_streamlit /semantic_search_streamlit

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]

FROM docker.io/library/python:3.8-slim AS export

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

COPY --from=build /usr/local/lib/python3.8/site-packages /usr/local/lib/python3.8/site-packages

COPY --from=build /usr/local/bin /usr/local/bin

COPY --from=build /semantic_search_streamlit /semantic_search_streamlit

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]
