FROM {{BASE_REGISTRY_URL}}/docker/library/python:3.8-slim AS base

ARG BUILD_TYPE
ARG GIT_BRANCH
ARG DRY_RUN
ARG DEBUG_LOGGING

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

FROM {{BASE_REGISTRY_URL}}/docker/library/python:3.8-slim AS build

WORKDIR /semantic_search_streamlit

COPY requirements.txt /semantic_search_streamlit/requirements.txt

ENV PIP_DISABLE_PIP_VERSION_CHECK=1

RUN pip install --no-cache-dir -r requirements.txt

COPY . /semantic_search_streamlit

RUN python -c "import streamlit, elasticsearch, openai, requests, dotenv"

FROM {{BASE_REGISTRY_URL}}/docker/library/python:3.8-slim AS run

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

COPY requirements.txt /semantic_search_streamlit/requirements.txt

RUN pip install --no-cache-dir -r requirements.txt

COPY . /semantic_search_streamlit

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]

FROM {{BASE_REGISTRY_URL}}/docker/library/python:3.8-slim AS export

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

COPY requirements.txt /semantic_search_streamlit/requirements.txt

RUN pip install --no-cache-dir -r requirements.txt

COPY . /semantic_search_streamlit

RUN printf '%s\n' '{"repo":"run","name":"llm-intent-search-streamlit","tag":"{{VERSION}}","qualifiedId":"llm-intent-search-streamlit:{{VERSION}}"}' > /build.json

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]
