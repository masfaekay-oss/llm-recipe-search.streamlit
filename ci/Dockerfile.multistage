# syntax=docker/dockerfile:1
# Multi-stage image for CI-CD-Pipeline/core/build-artifact-multistage (ci/Dockerfile.multistage).
# Final stage name "production" matches common Jenkins --target production.
ARG BUILD_TYPE
ARG GIT_BRANCH
ARG DRY_RUN
ARG DEBUG_LOGGING

FROM python:3.8-slim AS dependencies

WORKDIR /semantic_search_streamlit

COPY requirements.txt /semantic_search_streamlit/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

FROM python:3.8-slim AS production

WORKDIR /semantic_search_streamlit

COPY --from=dependencies /usr/local/lib/python3.8/site-packages /usr/local/lib/python3.8/site-packages
COPY --from=dependencies /usr/local/bin /usr/local/bin

COPY . /semantic_search_streamlit

EXPOSE 8502

CMD ["streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]
