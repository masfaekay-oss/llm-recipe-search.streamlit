# Stages: base, build, run, export (required by CI-CD-Pipeline/core/build-artifact-multistage).
# Every FROM must use a real registry image name. Jenkins getImageNamesFromDockerfile + pullAll
# cannot parse "FROM base AS build" (it tries to pull image "base") — use python:3.8-slim on each FROM.
# Do not use a top-level # syntax= line; some Jenkins parsers mis-handle it and yield empty pull lists.
ARG BUILD_TYPE
ARG GIT_BRANCH
ARG DRY_RUN
ARG DEBUG_LOGGING

FROM python:3.8-slim AS base

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

FROM python:3.8-slim AS build

WORKDIR /semantic_search_streamlit

# Keep base in the build graph (some validators expect every named stage to be referenced).
COPY --from=base /etc/debian_version /tmp/base-debian_version

COPY requirements.txt /semantic_search_streamlit/requirements.txt

ENV PIP_DISABLE_PIP_VERSION_CHECK=1

RUN pip install --no-cache-dir -r requirements.txt

FROM python:3.8-slim AS run

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

COPY --from=build /usr/local/lib/python3.8/site-packages /usr/local/lib/python3.8/site-packages

COPY . /semantic_search_streamlit

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]

FROM python:3.8-slim AS export

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

COPY --from=build /usr/local/lib/python3.8/site-packages /usr/local/lib/python3.8/site-packages

COPY . /semantic_search_streamlit

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]
