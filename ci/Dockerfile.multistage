# Stages: base, build, run, export (required by CI-CD-Pipeline/core/build-artifact-multistage).
# Every FROM must use a real registry image (not "FROM build AS run").
# Jenkins getImageNamesFromDockerfile also mis-reads COPY --from=base / COPY --from=build as images to
# pull — use COPY --from=0 / COPY --from=1 (0-based stage index: 0=base, 1=build, 2=run, 3=export).
# Do not use a top-level # syntax= line; some parsers mis-handle it.
ARG BUILD_TYPE
ARG GIT_BRANCH
ARG DRY_RUN
ARG DEBUG_LOGGING

FROM python:3.8-slim AS base

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

FROM python:3.8-slim AS build

WORKDIR /semantic_search_streamlit

# Reference stage 0 (base) without using the name "base" in COPY --from (Jenkins pullAll).
COPY --from=0 /etc/debian_version /tmp/base-debian_version

COPY requirements.txt /semantic_search_streamlit/requirements.txt

ENV PIP_DISABLE_PIP_VERSION_CHECK=1

RUN pip install --no-cache-dir -r requirements.txt

FROM python:3.8-slim AS run

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

COPY --from=1 /usr/local/lib/python3.8/site-packages /usr/local/lib/python3.8/site-packages

COPY . /semantic_search_streamlit

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]

FROM python:3.8-slim AS export

ENV PYTHONUNBUFFERED=1

WORKDIR /semantic_search_streamlit

COPY --from=1 /usr/local/lib/python3.8/site-packages /usr/local/lib/python3.8/site-packages

COPY . /semantic_search_streamlit

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]
