# Branch / release image for this repo (Streamlit). Not site-search: no Poetry, no pip install site-search.
# Pair with the same layout as Dockerfile.run so CI can build a branch image without internal parameterized_branch.sh.
FROM {{BASE_REGISTRY_URL}}/docker/library/python:3.8-slim

WORKDIR /semantic_search_streamlit

COPY requirements.txt /semantic_search_streamlit/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY . /semantic_search_streamlit

EXPOSE 8502

CMD ["python", "-m", "streamlit", "run", "app.py", "--server.port=8502", "--server.address=0.0.0.0"]
