# Example for Streamlit Community Cloud: paste into **App settings → Secrets** (TOML),
# or save as `.streamlit/secrets.toml` locally (do not commit real values).
# The app reads these keys after `os.environ` / `.env` (see `_config_str` in `app.py`).

# --- Site search (required for main flows) ---
SITE_SEARCH_API_BASE_URL = "https://your-public-or-vpn-reachable-host/"
SITE_SEARCH_API_PATH = "/search"
SITE_SEARCH_ALGO_TYPE = "MYRECIPES"

# Optional site-search tuning
# SITE_SEARCH_INTENT_PREVIEW_PATH = "/intent/preview"
# SITE_SEARCH_API_TIMEOUT = "120"
# SITE_SEARCH_API_AUTH_HEADER = ""
# SITE_SEARCH_STREAMLIT_USE_SEMANTIC = "true"

# --- Elasticsearch (optional; title hydration) ---
# ES_URL = "https://your-es-host:9200"
# ES_CLUSTER_URL = ""
# ES_USERNAME = ""
# ES_PASSWORD = ""
# ES_INDEX = "myrecipes"
# ES_FIELD_CUISINE = "cuisine.keyword"
# ES_FIELD_COURSE = "course.keyword"
# ES_FIELD_COOK_TIME = "totalTimeMinutes"

# --- Other (only if your code paths use them) ---
# OPENAI_API_KEY = ""
# THUMBOR_KEY = ""
